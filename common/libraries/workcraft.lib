# For most gates the following formula for the size was used:
# 4 + 2 * #transistors,
# where we assume that the gate is naturally negative and
# positive gates are implemented using an output inverter,
# and the input bubbles are implemented by inverters.
# The exceptions are BUF, LOGIC0 and LOGIC1, whose size is set to 0.

# --- COMBINATIONAL GATES

# Note that the buffer size and delay are intentionally low
GATE    BUF          0  O=I;
PIN *   NONINV  1 999 1 0.2 1 0.2

GATE    INV          8  ON=!I;
PIN *   INV     1 999 1 0.2 1 0.2


GATE    AND2        16  O=A*B;
PIN *   NONINV  1 999 1 0.2 1 0.2

GATE    NAND2       12  ON=!(A*B);
PIN *   INV     1 999 1 0.2 1 0.2

GATE    NAND2B      16  ON=!(!AN*B);
PIN AN  NONINV  1 999 1 0.2 1 0.2
PIN B   INV     1 999 1 0.2 1 0.2


GATE    AND3        20  O=A*B*C;
PIN *   NONINV  1 999 1 0.2 1 0.2

GATE    NAND3       16  ON=!(A*B*C);
PIN *   INV     1 999 1 0.2 1 0.2

GATE    NAND3B      20  ON=!(!AN*B*C);
PIN AN  NONINV  1 999 1 0.2 1 0.2
PIN B   INV     1 999 1 0.2 1 0.2
PIN C   INV     1 999 1 0.2 1 0.2


GATE    AND4        24  O=A*B*C*D;
PIN *   NONINV  1 999 1 0.2 1 0.2

GATE    NAND4       20  ON=!(A*B*C*D);
PIN *   INV     1 999 1 0.2 1 0.2

GATE    NAND4B      24  ON=!(!AN*B*C*D);
PIN AN  NONINV  1 999 1 0.2 1 0.2
PIN B   INV     1 999 1 0.2 1 0.2
PIN C   INV     1 999 1 0.2 1 0.2
PIN D   INV     1 999 1 0.2 1 0.2

GATE    NAND4BB     28  ON=!(!AN*!BN*C*D);
PIN AN  NONINV  1 999 1 0.2 1 0.2
PIN BN  NONINV  1 999 1 0.2 1 0.2
PIN C   INV     1 999 1 0.2 1 0.2
PIN D   INV     1 999 1 0.2 1 0.2


GATE    OR2         16  O=A+B;
PIN *   NONINV  1 999 1 0.2 1 0.2

GATE    NOR2        12  ON=!(A+B);
PIN *   INV     1 999 1 0.2 1 0.2

GATE    NOR2B       16  ON=!(!AN+B);
PIN AN  NONINV  1 999 1 0.2 1 0.2
PIN B   INV     1 999 1 0.2 1 0.2


GATE    OR3         20  O=A+B+C;
PIN *   NONINV  1 999 1 0.2 1 0.2

GATE    NOR3        16  ON=!(A+B+C);
PIN *   INV     1 999 1 0.2 1 0.2

GATE    NOR3B       20  ON=!(!AN+B+C);
PIN AN  NONINV  1 999 1 0.2 1 0.2
PIN B   INV     1 999 1 0.2 1 0.2
PIN C   INV     1 999 1 0.2 1 0.2


GATE    OR4         24  O=A+B+C+D;
PIN *   NONINV  1 999 1 0.2 1 0.2

GATE    NOR4        20  ON=!(A+B+C+D);
PIN *   INV     1 999 1 0.2 1 0.2

GATE    NOR4B       24  ON=!(!AN+B+C+D);
PIN AN  NONINV  1 999 1 0.2 1 0.2
PIN B   INV     1 999 1 0.2 1 0.2
PIN C   INV     1 999 1 0.2 1 0.2
PIN D   INV     1 999 1 0.2 1 0.2

GATE    NOR4BB      28  ON=!(!AN+!BN+C+D);
PIN AN  NONINV  1 999 1 0.2 1 0.2
PIN BN  NONINV  1 999 1 0.2 1 0.2
PIN C   INV     1 999 1 0.2 1 0.2
PIN D   INV     1 999 1 0.2 1 0.2


GATE    AO21        20  O=A1*A2+B;
PIN *   NONINV  1 999 1 0.2 1 0.2

GATE    AOI21       16  ON=!(A1*A2+B);
PIN *   INV     1 999 1 0.2 1 0.2

GATE    AO211       24  O=A1*A2+B+C;
PIN *   NONINV  1 999 1 0.2 1 0.2

GATE    AOI211      20  ON=!(A1*A2+B+C);
PIN *   INV     1 999 1 0.2 1 0.2

GATE    AO22        24  O=A1*A2+B1*B2;
PIN *   NONINV  1 999 1 0.2 1 0.2

GATE    AOI22       20  ON=!(A1*A2+B1*B2);
PIN *   INV     1 999 1 0.2 1 0.2

GATE    AO221       28  O=A1*A2+B1*B2+C;
PIN *   NONINV  1 999 1 0.2 1 0.2

GATE    AOI221      24  ON=!(A1*A2+B1*B2+C);
PIN *   INV     1 999 1 0.2 1 0.2

GATE    AO222       32  O=A1*A2+B1*B2+C1*C2;
PIN *   NONINV    1 999 1 0.2 1 0.2

GATE    AOI222      28  ON=!(A1*A2+B1*B2+C1*C2);
PIN *   INV     1 999 1 0.2 1 0.2

GATE    AO31        24  O=A1*A2*A3+B;
PIN *   NONINV  1 999 1 0.2 1 0.2

GATE    AOI31       20  ON=!(A1*A2*A3+B);
PIN *   INV     1 999 1 0.2 1 0.2

GATE    AO32        28  O=A1*A2*A3+B1*B2;
PIN *   NONINV  1 999 1 0.2 1 0.2

GATE    AOI32       24  ON=!(A1*A2*A3+B1*B2);
PIN *   INV     1 999 1 0.2 1 0.2

# Note: Petrify fails to read "O=A1*A2*A3+B1*B2*B3"
#GATE    AO33        32  O=A1*A2*A3+B1*B2*B3;
#PIN *   NONINV  1 999 1 0.2 1 0.2

GATE    AOI33       28  ON=!(A1*A2*A3+B1*B2*B3);
PIN *   INV     1 999 1 0.2 1 0.2

GATE    AOI2BB1     24  ON=!(!A1N*!A2N+B);
PIN A1N NONINV  1 999 1 0.2 1 0.2
PIN A2N NONINV  1 999 1 0.2 1 0.2
PIN B   INV     1 999 1 0.2 1 0.2

GATE    AOI2BB2     28  ON=!(!A1N*!A2N+B1*B2);
PIN A1N NONINV  1 999 1 0.2 1 0.2
PIN A2N NONINV  1 999 1 0.2 1 0.2
PIN B1  INV     1 999 1 0.2 1 0.2
PIN B2  INV     1 999 1 0.2 1 0.2

GATE    AOA212      28  O=(A1*A2+B)*(C1+C2);
PIN *   NONINV  1 999 1 0.2 1 0.2

GATE    AOAI212     24  ON=!((A1*A2+B)*(C1+C2));
PIN *   INV     1 999 1 0.2 1 0.2


GATE    OA21        20  O=(A1+A2)*B;
PIN *   NONINV  1 999 1 0.2 1 0.2

GATE    OAI21       16  ON=!((A1+A2)*B);
PIN *   INV     1 999 1 0.2 1 0.2

GATE    OA211       24  O=(A1+A2)*B*C;
PIN *   NONINV  1 999 1 0.2 1 0.2

GATE    OAI211      20  ON=!((A1+A2)*B*C);
PIN *   INV     1 999 1 0.2 1 0.2

GATE    OA22        24  O=(A1+A2)*(B1+B2);
PIN *   NONINV  1 999 1 0.2 1 0.2

GATE    OAI22       20  ON=!((A1+A2)*(B1+B2));
PIN *   INV     1 999 1 0.2 1 0.2

GATE    OA221       28  O=(A1+A2)*(B1+B2)*C;
PIN *   NONINV  1 999 1 0.2 1 0.2

GATE    OAI221      24  ON=!((A1+A2)*(B1+B2)*C);
PIN *   INV     1 999 1 0.2 1 0.2

GATE    OA222       32  O=(A1+A2)*(B1+B2)*(C1+C2);
PIN *   NONINV  1 999 1 0.2 1 0.2

GATE    OAI222      28  ON=!((A1+A2)*(B1+B2)*(C1+C2));
PIN *   INV     1 999 1 0.2 1 0.2

GATE    OA31        24  O=(A1+A2+A3)*B;
PIN *   NONINV  1 999 1 0.2 1 0.2

GATE    OAI31       20  ON=!((A1+A2+A3)*B);
PIN *   INV     1 999 1 0.2 1 0.2

GATE    OA32        28  O=(A1+A2+A3)*(B1+B2);
PIN *   NONINV  1 999 1 0.2 1 0.2

GATE    OAI32       24  ON=!((A1+A2+A3)*(B1+B2));
PIN *   INV     1 999 1 0.2 1 0.2

# Note: Petrify fails to read "O=(A1+A2+A3)*(B1+B2+B3)"
#GATE    OA33        32  O=(A1+A2+A3)*(B1+B2+B3);
#PIN *   NONINV  1 999 1 0.2 1 0.2

GATE    OAI33       28  ON=!((A1+A2+A3)*(B1+B2+B3));
PIN *   INV     1 999 1 0.2 1 0.2

GATE    OAI2BB1     24  ON=!((!A1N+!A2N)*B);
PIN A1N NONINV  1 999 1 0.2 1 0.2
PIN A2N NONINV  1 999 1 0.2 1 0.2
PIN B   INV     1 999 1 0.2 1 0.2

GATE    OAI2BB2     28  ON=!((!A1N+!A2N)*(B1+B2));
PIN A1N NONINV  1 999 1 0.2 1 0.2
PIN A2N NONINV  1 999 1 0.2 1 0.2
PIN B1  INV     1 999 1 0.2 1 0.2
PIN B2  INV     1 999 1 0.2 1 0.2

GATE    OAOI212     24  ON=!((A1+A2)*B+C1*C2);
PIN *   INV     1 999 1 0.2 1 0.2

GATE    OAO212      28  O=(A1+A2)*B+C1*C2;
PIN *   NONINV  1 999 1 0.2 1 0.2

# Inverted Majority-of-3 (i.e. Minority)
# CMOS implementation: pull-up stack: A*(B+C)+B*C, pull-down stack: A*(B+C)+B*C, so 10 FETs
GATE    MAJI3       24  ON=!(A*B+A*C+B*C);
PIN *   INV     1 999 1 0.2 1 0.2

# Majority-of-3, built from MAJI3 above by adding an output inverter, so 12 FETs
GATE    MAJ3        28  O=A*B+A*C+B*C;
PIN *   NONINV  1 999 1 0.2 1 0.2
 

# --- CONSTANTS

GATE    LOGIC1       0   O=CONST1;

GATE    LOGIC0       0   O=CONST0;


# --- BINATE GATES

# Implementation of XOR2 is based on transmission gates:
# input A is inverted and input B is inverted twice, and then !B or !!B go via 2 transmission gates;
# these transmission gates are controlled by A and its inversion;
# the outputs of these transmission gates are joined and go to the output
# hence there are 3 inverters and 2 transmission gates altogether, i.e 10 FETs in total
#GATE    XOR2        24  O=A*!B+!A*B;
#PIN *   UNKNOWN 1 999 1 0.2 1 0.2
 
# Implementation of XNOR2 is similar to that of XOR2, just the polarities
# of transmission gates controls are flipped, i.e. 10 FETs in total
#GATE    XNOR2        24  O=!A*!B+A*B;
#PIN *   UNKNOWN 1 999 1 0.2 1 0.2
 
# 22 FETs
#GATE    XOR3        48  O=A*!B*!C+!A*B*!C+!A*!B*C+A*B*C;
#PIN *   UNKNOWN 1 999 1 0.2 1 0.2

# 22 FETs
#GATE    XNOR3       48  ON=!(A*!B*!C+!A*B*!C+!A*!B*C+A*B*C);
#PIN *   UNKNOWN 1 999 1 0.2 1 0.2

 
# Implementation of MUX2 is based on transmission gates:
# the inputs I0 and I1 are inverted, and then go via 2 transmission gates;
# these transmission gates are controlled by S and its inversion;
# the outputs of these transmission gates are joined and go via an output inverter 
# hence there are 4 inverters and 2 transmission gates altogether, i.e. 12 FETs in total;
# this gate should not glitch when I0=I1 and S switches, hence the redundant "overtake"
# cube I0*I1 in the equation
#GATE    MUX2        28  O=I0*!S0+I1*S0+I0*I1;
#PIN I0  NONINV  1 999 1 0.2 1 0.2
#PIN I1  NONINV  1 999 1 0.2 1 0.2
#PIN S0  UNKNOWN 1 999 1 0.2 1 0.2
 
# Same as MUX2 but without the output inverter
# This gate should not glitch when I0=I1 and S switches,
# hence the redundant "overtake" cube !I0*!I1 in the equation
#GATE    IMUX2		24  O=!I0*!S0+!I1*S0+!I0*!I1;
#PIN I0  INV     1 999 1 0.2 1 0.2
#PIN I1  INV     1 999 1 0.2 1 0.2
#PIN S0  UNKNOWN 1 999 1 0.2 1 0.2
 
# The number of FETs in positive MUXes of sizes more than 2 is smaller than
# that in negative IMUXes in one of the "real" libraries for some reason
 
# Note that for [I]MUX3 one has to define what happens when S0=S1=1;
# one of the "real" libraries sets the value to [!]I2 so the equations below
# follow this approach; however this may be not portable
 
# 20 FETs
#GATE    MUX3        44  O=S1*I2+!S1*(S0*I1+!S0*I0);
#PIN I0  NONINV  1 999 1 0.2 1 0.2
#PIN I1  NONINV  1 999 1 0.2 1 0.2
#PIN I2  NONINV  1 999 1 0.2 1 0.2
#PIN S0  UNKNOWN 1 999 1 0.2 1 0.2
#PIN S1  UNKNOWN 1 999 1 0.2 1 0.2
 
# 24 FETs
#GATE    IMUX3       52  O=!(S1*I2+!S1*(S0*I1+!S0*I0));
#PIN I0  INV     1 999 1 0.2 1 0.2
#PIN I1  INV     1 999 1 0.2 1 0.2
#PIN I2  INV     1 999 1 0.2 1 0.2
#PIN S0  UNKNOWN 1 999 1 0.2 1 0.2
#PIN S1  UNKNOWN 1 999 1 0.2 1 0.2
 
# 26 FETs
#GATE    MUX4        56  O=I0*!S0*!S1+I1*S0*!S1+I2*!S0*S1+I3*S0*S1;
#PIN I0  NONINV  1 999 1 0.2 1 0.2
#PIN I1  NONINV  1 999 1 0.2 1 0.2
#PIN I2  NONINV  1 999 1 0.2 1 0.2
#PIN I3  NONINV  1 999 1 0.2 1 0.2
#PIN S0  UNKNOWN 1 999 1 0.2 1 0.2
#PIN S1  UNKNOWN 1 999 1 0.2 1 0.2
 
# 30 FETs
#GATE    IMUX4       64  O=!I0*!S0*!S1+!I1*S0*!S1+!I2*!S0*S1+!I3*S0*S1;
#PIN I0  INV     1 999 1 0.2 1 0.2
#PIN I1  INV     1 999 1 0.2 1 0.2
#PIN I2  INV     1 999 1 0.2 1 0.2
#PIN I3  INV     1 999 1 0.2 1 0.2
#PIN S0  UNKNOWN 1 999 1 0.2 1 0.2
#PIN S1  UNKNOWN 1 999 1 0.2 1 0.2


# --- ASYNCH LATCHES

# C-element
LATCH   C2          20  Q=A*B+(A+B)*Q_NEXT;
PIN A   NONINV  1 999 1 0.2 1 0.2
PIN B   NONINV  1 999 1 0.2 1 0.2
SEQ Q   Q_NEXT ASYNCH

# Inverting C-element
LATCH   NC2         20  QN=!A*!B+(!A+!B)*QN_NEXT;
PIN A   INV     1 999 1 0.2 1 0.2
PIN B   INV     1 999 1 0.2 1 0.2
SEQ QN  QN_NEXT ASYNCH


# The following latches are not used. Use them at your own risk.

# Cross-coupled NAND (SR latch)
#LATCH   SR_LATCH_NAND        40  Q=!S+R*Q_NEXT;
#PIN S   INV     1 999 1 .2 1 .2
#PIN R   NONINV  1 999 1 .2 1 .2
#SEQ Q   Q_NEXT ASYNCH

# Cross-coupled NOR (SR latch)
#LATCH   SR_LATCH_NOR         40  Q=S+!R*Q_NEXT;
#PIN S   NONINV  1 999 1 .2 1 .2
#PIN R   INV     1 999 1 .2 1 .2
#SEQ Q   Q_NEXT ASYNCH

# Cross-coupled NAND (RS latch)
#LATCH   RS_LATCH_NAND        40  Q=!R+S*Q_NEXT;
#PIN S   INV     1 999 1 .2 1 .2
#PIN R   NONINV  1 999 1 .2 1 .2
#SEQ Q   Q_NEXT ASYNCH

# Cross-coupled NOR (RS latch)
#LATCH   RS_LATCH_NOR         40  Q=!R*Q_NEXT+!R*S;
#PIN S   NONINV  1 999 1 .2 1 .2
#PIN R   INV     1 999 1 .2 1 .2
#SEQ Q   Q_NEXT ASYNCH
